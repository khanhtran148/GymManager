{
  "name": "gymmanager-e2e",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "npx playwright test",
    "test:auth": "npx playwright test specs/auth.spec.ts",
    "test:gym-houses": "npx playwright test specs/gym-houses.spec.ts",
    "test:members": "npx playwright test specs/members.spec.ts",
    "test:subscriptions": "npx playwright test specs/subscriptions.spec.ts",
    "test:bookings": "npx playwright test specs/bookings.spec.ts",
    "test:finance": "npx playwright test specs/finance.spec.ts",
    "test:staff": "npx playwright test specs/staff.spec.ts",
    "test:announcements": "npx playwright test specs/announcements.spec.ts",
    "test:navigation": "npx playwright test specs/navigation.spec.ts",
    "test:api": "npx playwright test --project=api",
    "test:ui": "npx playwright test --project=ui",
    "test:journeys": "npx playwright test --project=journeys",
    "test:smoke": "npx playwright test --project=api --grep @smoke",
