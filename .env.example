# =============================================================================
# GymManager — Local Development Environment
# =============================================================================
# Copy this file and the instructions below to set up local dev.
#
# 1. Start infrastructure:
#      docker compose up -d
#
# 2. API (no env vars needed — uses appsettings.Local.json):
#      dotnet run --project src/apps/GymManager.Api
#      → http://localhost:5050
#
# 3. Frontend (reads .env.local automatically):
#      cd src/apps/gymmanager-web && npm run dev
#      → http://localhost:3000
#
# 4. E2E tests (reads .env automatically):
#      cd tests/GymManager.E2E && npx playwright test
#
# =============================================================================
# Frontend (.env.local in src/apps/gymmanager-web/)
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:5050/api/v1

# =============================================================================
# E2E Tests (.env in tests/GymManager.E2E/)
# =============================================================================
BASE_URL=http://localhost:3000
API_URL=http://localhost:5050/api/v1

# =============================================================================
# API (appsettings.Local.json in src/apps/GymManager.Api/)
# =============================================================================
# ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=gymmanager;Username=postgres;Password=postgres
# Jwt__Secret=SuperSecretKeyForGymManagerLocalDev2024!@#$%^&*()
# RabbitMQ__Username=guest
# RabbitMQ__Password=guest
